{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "maison-mcp",
      "version": "0.1.0",
      "title": "Maison MCP"
    },
    "tools": [
      {
        "name": "list_budget_categories",
        "title": "List budget categories",
        "description": "List every budget category for the current period, with the budgeted amount, the actual spend, the delta, and the sub-postes breakdown.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "get_budget_category",
        "title": "Get budget category",
        "description": "Return the detail (budget, actual, delta, sub-postes) for a single budget category by its key (e.g. 'logement', 'energie', 'alimentation').",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "key": {
              "type": "string",
              "minLength": 1,
              "description": "Category key such as 'logement', 'energie', 'transport', 'alimentation', etc."
            }
          },
          "required": [
            "key"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_transactions",
        "title": "List transactions",
        "description": "List seed transactions, optionally filtered by category key and/or a case-insensitive text query on the label.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "category": {
              "description": "Optional category key filter.",
              "type": "string"
            },
            "query": {
              "description": "Optional case-insensitive substring to match on the label.",
              "type": "string"
            },
            "limit": {
              "description": "Max rows to return (default 50).",
              "type": "integer",
              "minimum": 1,
              "maximum": 500
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_energy_status",
        "title": "Get energy status",
        "description": "Return the current energy dashboard snapshot: last reading date, monthly-due flag, KPIs, and recent history.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_rooms",
        "title": "List rooms",
        "description": "List every room in the Maison space with its key, label, and icon.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      }
    ]
  }
}
